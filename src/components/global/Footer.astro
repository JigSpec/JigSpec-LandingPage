---
const year = new Date().getFullYear();
---

<footer class="mt-auto border-t border-muted/20">
  <div class="max-w-5xl mx-auto px-6 py-8 flex flex-col md:flex-row md:items-center md:justify-between gap-4 text-sm text-muted">
    <p>&copy; {year} JigSpec</p>
    <ul class="flex flex-wrap items-center gap-6">
      <li>
        <a
          href="https://jigspec.com"
          data-event="footer:link_click"
          data-link-location="docs"
          class="hover:text-accent transition-colors"
        >
          Docs
        </a>
      </li>
      <li>
        <a
          href="mailto:hi@jigspec.com"
          data-event="footer:link_click"
          data-link-location="email"
          class="hover:text-accent transition-colors"
        >
          hi@jigspec.com
        </a>
      </li>
      <li>
        <a
          href="https://github.com/JigSpec"
          rel="noopener"
          data-event="footer:link_click"
          data-link-location="github"
          class="hover:text-accent transition-colors"
        >
          GitHub
        </a>
      </li>
    </ul>
  </div>
</footer>
